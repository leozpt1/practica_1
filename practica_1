class Producto:
    def __init__(self, nombre, precio, stock, descuento, categoria):
        self.__nombre = nombre
        self.__precio = precio
        self.__stock = stock
        self.__descuento = descuento
        self.__categoria = categoria 

    def get_nombre(self):
        return self.__nombre
    
    def get_precio(self):
        return self.__precio
    
    def get_stock(self):
        return self.__stock
    
    def get_descuento(self):
        return self.__descuento

    def get_categoria(self):
        return self.__categoria
#también agregué los getters hasta este punto de los commits pero se me fue poner en el commit numero 2 olvidé escribirlo

    def set_nombre(self, nombre):
        self.__nombre = nombre

    def set_precio(self, precio):
        if precio > 0:
            self.__precio = precio
        else:
            print("El precio debe ser mayor a 0")

    def set_stock(self, stock):
        if stock >= 0:
            self.__stock = stock
        else:
            print("El stock no puede ser negativo")

    def set_descuento(self, descuento):
        if 0 <= descuento <= 100:
            self.__descuento = descuento
        else:
            print("El descuento debe estar entre 0 y 100")

    def set__categoria(self, categoria):
        self.__categoria = categoria

    def calcular_precio_final(self):
        return self.__precio - (self.__precio * self.__descuento / 100)

    def vender(self, cantidad):
        if cantidad <= self.__stock:
            self.__stock -= cantidad
            print("Venta realizada")
        else:
            print("No hay suficiente stock")

    def info(self):
        print("Nombre:", self.__nombre)
        print("Precio:", self.__precio)
        print("Stock:", self.__stock)
        print("Descuento:", self.__descuento)
        print("Categoría:", self.__categoria)

    p1 = Producto("Laptop", 15000, 10, 10, "Electrónica")

    p1.info()
    print("Precio con descuento", p1.calcular_precio_final())

    p1.vender(3)
    p1.info()